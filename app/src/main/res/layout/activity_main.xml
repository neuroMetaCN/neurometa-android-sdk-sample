<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 系统时间 -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:16"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />

            <!-- 主标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEUROMETA"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="0.1"
                android:layout_marginTop="8dp" />

            <!-- 副标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EEG DATA ACQUISITION SDK"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.15"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- 状态卡片区域 (3列) -->
        <LinearLayout
            android:id="@+id/layoutStatusCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:background="@color/surface_dark"
            android:padding="16dp">

            <!-- BATTERY -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATTERY"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvBatteryLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- STATUS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvWearStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:layout_marginTop="8dp" />

            </LinearLayout>



        </LinearLayout>

        <!-- 设备列表区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 设备区域标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DEVICES"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDeviceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FOUND"
                    android:textSize="12sp"
                    android:textColor="@color/accent_red"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <!-- 设备列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:itemCount="2"
                tools:listitem="@layout/item_device" />

            <!-- 连接状态（简化显示） -->
            <TextView
                android:id="@+id/tvDeviceInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 实时 EEG 区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- EEG 区域标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REALTIME EEG"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvSamplingRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- Hz LIVE"
                    android:textSize="12sp"
                    android:textColor="@color/accent_green"
                    android:letterSpacing="0.05" />

            </LinearLayout>

            <!-- 通道选择器 -->
            <TextView
                android:id="@+id/tvChannelInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CH1 · FP1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <!-- EEG 波形图 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/chart_background">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartEEG"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>


        </LinearLayout>

        <!-- ============ SPECTRAL COMPONENTS ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SPECTRAL COMPONENTS"
                    android:textSize="12sp"
                    android:textColor="@color/section_label"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvPsdStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INIT"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- 频段卡片容器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_dark"
                android:padding="12dp">

                <!-- DELTA -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DELTA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/band_delta"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDeltaPower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0.0 μV"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartDelta"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_alignParentBottom="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:text="Delta"
                        android:textSize="10sp"
                        android:textColor="@color/band_delta"
                        android:alpha="0.6" />
                </RelativeLayout>

                <!-- THETA -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THETA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/band_theta"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvThetaPower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0.0 μV"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartTheta"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_alignParentBottom="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:text="Theta"
                        android:textSize="10sp"
                        android:textColor="@color/band_theta"
                        android:alpha="0.6" />
                </RelativeLayout>

                <!-- ALPHA -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALPHA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/band_alpha"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvAlphaPower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0.0 μV"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartAlpha"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_alignParentBottom="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:text="Alpha"
                        android:textSize="10sp"
                        android:textColor="@color/band_alpha"
                        android:alpha="0.6" />
                </RelativeLayout>

                <!-- BETA -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BETA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/band_beta"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvBetaPower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0.0 μV"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartBeta"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_alignParentBottom="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:text="Beta"
                        android:textSize="10sp"
                        android:textColor="@color/band_beta"
                        android:alpha="0.6" />
                </RelativeLayout>

                <!-- GAMMA -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GAMMA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/band_gamma"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvGammaPower"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0.0 μV"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartGamma"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_alignParentBottom="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:text="Gamma"
                        android:textSize="10sp"
                        android:textColor="@color/band_gamma"
                        android:alpha="0.6" />
                </RelativeLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ============ PRECISION CONTROLS ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRECISION CONTROLS"
                android:textSize="12sp"
                android:textColor="@color/section_label"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_dark"
                android:padding="16dp">

                <!-- GAIN 控制 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="GAIN"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_red"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvGainValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0x"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekGain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="99"
                        android:progress="9"
                        android:progressTint="@color/accent_red"
                        android:thumbTint="@color/accent_red"
                        android:progressBackgroundTint="@color/control_track" />
                </LinearLayout>

                <!-- WINDOW 控制 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="WINDOW"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_green"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvWindowValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2.0s"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekWindow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="70"
                        android:progress="30"
                        android:progressTint="@color/accent_green"
                        android:thumbTint="@color/accent_green"
                        android:progressBackgroundTint="@color/control_track" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- 扫描设备按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SCAN DEVICES"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@color/accent_red"
            app:cornerRadius="4dp" />

        <!-- 断开连接按钮 (隐藏状态) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="DISCONNECT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/accent_red"
            app:strokeWidth="1dp"
            android:textColor="@color/accent_red"
            app:cornerRadius="4dp" />

        <!-- 控制台日志区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 日志区域标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CONSOLE LOG"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLEAR"
                    android:textSize="12sp"
                    android:textColor="@color/accent_red"
                    android:letterSpacing="0.1"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- 日志内容 -->
            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/surface_dark"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp" />

            </ScrollView>

        </LinearLayout>

        <!-- Record EDF 链接 -->
        <TextView
            android:id="@+id/btnRecordEdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Record EDF"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:padding="16dp" />

        <!-- 录制状态 (隐藏) -->
        <TextView
            android:id="@+id/tvRecordStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textSize="12sp"
            android:textColor="@color/accent_green"
            android:gravity="center" />

        <!-- 隐藏的状态视图 (兼容旧代码) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDataInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="horizontal" />

    </LinearLayout>
</ScrollView>
